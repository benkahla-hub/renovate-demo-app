{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
    "packageRules": [
      {
      "matchDepTypes": ["devDependencies"],  // <-- Matcher
      "groupName": "dev dependencies"        // <-- Aktion
      },
      {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "patch-minor dependencies",
      "groupSlug": "patch-minor",
      "enabled": true,
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major dependencies",
      "groupSlug": "major",
      "enabled": true,
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}
