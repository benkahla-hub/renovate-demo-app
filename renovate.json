{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
    "packageRules": [
      {
      "matchUpdateTypes": ["minor","patch"],
      "groupName": "patch-minor dependencies",
      "groupSlug": "patch-minor",
      "enabled": true,
      "matchPackageNames": ["*"]
    },
    {
      "matchPackageNames": ["axios"],
      "enabled": false
    }
  ]
}
