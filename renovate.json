{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "mergeConfidence:all-badges"
  ],
    "prConcurrentLimit": 3,
    "packageRules": [
      {
      "matchUpdateTypes": ["minor","patch"],
      "groupName": "patch-minor dependencies",
      "groupSlug": "patch-minor",
      "enabled": true,
      "automerge": true,
      "automergeType": "pr",
      "matchPackageNames": ["*"]
    },
    {
      "matchPackageNames": ["axios"],
      "enabled": false
    },
      {
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major dependencies",
      "groupSlug": "major",
      "enabled": true,
      "matchPackageNames": [
        "*"
      ]
     } 
  ]
}
